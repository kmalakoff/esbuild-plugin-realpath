{
  "name": "esbuild-plugin-realpath",
  "version": "1.1.3",
  "description": "A plugin to resolve the fs.realpath for modules in monorepos targeting the browser and node",
  "keywords": [
    "esbuild",
    "plugin",
    "realpath",
    "npm",
    "yarn",
    "pnpm",
    "lerna",
    "monorepo",
    "react-native",
    "react-native-web"
  ],
  "license": "MIT",
  "author": "",
  "main": "dist/cjs/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsds build",
    "deploy": "tsds deploy",
    "format": "biome check --write --unsafe src/ test/",
    "test": "tsds test:node --no-timeouts",
    "test:engines": "nvu engines npm test",
    "version": "tsds version"
  },
  "dependencies": {
    "browser-resolve": "^2.0.0",
    "esbuild": "*",
    "resolve": "^1.22.9",
    "resolve-once": "^0.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.2",
    "depcheck": "^1.4.7",
    "fs-extra": "^11.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-dev-stack": "^1.2.6"
  },
  "engines": {
    "node": ">=12"
  },
  "tsds": {
    "source": "src/index.mjs",
    "targets": [
      "cjs"
    ]
  }
}
